# ============================================================
# LLM Provider — categorizer, enricher, OCR, reporter
# LLM провайдер — категоризатор, энричер, OCR, репортер
# ============================================================

# Provider selection: ollama | openrouter | claude
# Выбор провайдера: ollama | openrouter | claude
LLM_PROVIDER=ollama

# LLM request timeout in seconds (default: 120)
# Таймаут запроса к LLM в секундах (по умолчанию: 120)
LLM_TIMEOUT=120

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================================
# Browser & Instagram Auth
# Браузер и аутентификация Instagram
# ============================================================

# Browser for cookie extraction: firefox | chrome
# Браузер для чтения куков: firefox | chrome
BROWSER=firefox

# Firefox profile path — yt-dlp reads cookies from here
# Путь к профилю Firefox — yt-dlp читает из него cookies
# Find: ls ~/snap/firefox/common/.mozilla/firefox/ or ls ~/.mozilla/firefox/
# Найти: ls ~/snap/firefox/common/.mozilla/firefox/ или ls ~/.mozilla/firefox/
FIREFOX_PROFILE=~/snap/firefox/common/.mozilla/firefox

# Chrome profile path (if BROWSER=chrome)
# Путь к профилю Chrome (если BROWSER=chrome)
# Windows: C:\Users\<Name>\AppData\Local\Google\Chrome\User Data
# Linux:   ~/.config/google-chrome
# macOS:   ~/Library/Application Support/Google/Chrome
CHROME_PROFILE=

# Instagram login for instaloader fallback (leave empty if using ~/.instaloader-session)
# Логин Instagram для instaloader (оставь пустым если используешь сессию)
INSTA_USER=
INSTA_PASS=

# ============================================================
# Instagram Fetch Tuning — rate limiting & timeouts
# Настройка задержек и таймаутов при скачивании
# ============================================================

# Delay range between requests (seconds) — increase to reduce ban risk
# Задержка между запросами (секунды) — увеличь при риске бана
FETCH_SLEEP_MIN=3
FETCH_SLEEP_MAX=10

# Socket timeout for yt-dlp connections (seconds)
# Таймаут сокета для yt-dlp (секунды)
FETCH_SOCKET_TIMEOUT=60

# Number of download retries on failure
# Количество повторных попыток при ошибке скачивания
FETCH_RETRIES=5
FETCH_EXTRACTOR_RETRIES=3

# Hard timeout for the entire yt-dlp subprocess (seconds)
# Жёсткий таймаут для всего процесса yt-dlp (секунды)
FETCH_PROCESS_TIMEOUT=120

# Timeout for Instagram private API fallback requests (seconds)
# Таймаут для запросов к Instagram API (секунды)
FETCH_API_TIMEOUT=20

# ============================================================
# Video Analysis Pipeline (run_analysis.py)
# ============================================================

# Ollama base URL
# Windows/macOS/Linux: установить с https://ollama.com/download
# После установки: ollama pull gemma3:4b
# Проверить: ollama list
OLLAMA_URL=http://localhost:11434

# Ollama model для OCR и анализа отчёта
# Vision-capable (нужны для OCR): gemma3:4b, llava:7b, moondream
# ВАЖНО: текстовые модели (gemma2, llama3) НЕ поддерживают vision — OCR не заработает
OLLAMA_MODEL=gemma3:4b

# Whisper model size (влияет на качество и скорость)
# tiny < base < small < medium < large-v3
# CPU: рекомендуется base или small
# GPU (CUDA): можно medium или large-v3
WHISPER_MODEL=base

# Whisper device: auto | cpu | cuda
WHISPER_DEVICE=auto

# Whisper compute type: int8 (CPU) | float16 (GPU) | float32
WHISPER_COMPUTE_TYPE=int8

# Путь к ffmpeg (опционально — только если ffmpeg не найден автоматически)
# Автопоиск: FFMPEG_PATH → bin/ffmpeg.exe → системный PATH
#
# Windows без установки в PATH:
#   1. Скачай ffmpeg: https://github.com/BtbN/FFmpeg-Builds/releases
#      (файл ffmpeg-master-latest-win64-gpl.zip или essentials)
#   2. Распакуй, скопируй ffmpeg.exe и ffprobe.exe в папку bin/ проекта
#   3. Больше ничего делать не нужно — скрипт найдёт сам
#
# Либо укажи путь явно:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
