BROWSER=firefox        # firefox или chrome

# Путь к профилю Firefox — yt-dlp читает из него cookies для скачивания
# Найти: ls ~/snap/firefox/common/.mozilla/firefox/ или ls ~/.mozilla/firefox/
FIREFOX_PROFILE=~/snap/firefox/common/.mozilla/firefox

# Путь к профилю Chrome (если BROWSER=chrome)
# Windows: C:\Users\<Name>\AppData\Local\Google\Chrome\User Data
# Linux:   ~/.config/google-chrome
# macOS:   ~/Library/Application Support/Google/Chrome
CHROME_PROFILE=

# Instagram логин для instaloader (fallback скачивания картинок)
# Оставь пустым если используешь ~/.instaloader-session (рекомендуется)
INSTA_USER=
INSTA_PASS=

# ============================================================
# Video Analysis Pipeline (run_analysis.py)
# ============================================================

# Ollama base URL
# Windows/macOS/Linux: установить с https://ollama.com/download
# После установки: ollama pull gemma3:4b
# Проверить: ollama list
OLLAMA_URL=http://localhost:11434

# Ollama model для OCR и анализа отчёта
# Vision-capable (нужны для OCR): gemma3:4b, llava:7b, moondream
# ВАЖНО: текстовые модели (gemma2, llama3) НЕ поддерживают vision — OCR не заработает
OLLAMA_MODEL=gemma3:4b

# Whisper model size (влияет на качество и скорость)
# tiny < base < small < medium < large-v3
# CPU: рекомендуется base или small
# GPU (CUDA): можно medium или large-v3
WHISPER_MODEL=base

# Whisper device: auto | cpu | cuda
WHISPER_DEVICE=auto

# Whisper compute type: int8 (CPU) | float16 (GPU) | float32
WHISPER_COMPUTE_TYPE=int8

# Путь к ffmpeg (опционально — только если ffmpeg не найден автоматически)
# Автопоиск: FFMPEG_PATH → bin/ffmpeg.exe → системный PATH
#
# Windows без установки в PATH:
#   1. Скачай ffmpeg: https://github.com/BtbN/FFmpeg-Builds/releases
#      (файл ffmpeg-master-latest-win64-gpl.zip или essentials)
#   2. Распакуй, скопируй ffmpeg.exe и ffprobe.exe в папку bin/ проекта
#   3. Больше ничего делать не нужно — скрипт найдёт сам
#
# Либо укажи путь явно:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
